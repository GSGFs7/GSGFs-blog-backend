{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "Bundler",
    "outDir": "web/static/js",
    "rootDir": "web/typescript",
    "strict": true,
    "sourceMap": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "esModuleInterop": true,
    "noEmit": true,
    "types": ["vitest/globals"]
  },
  "include": ["web/typescript/**/*.ts", "web/typescript/**/*.tsx"]
}
