DEBUG=True

# Django 配置
DJANGO_SECRET_KEY=<随机字符串> # Django加密需要
DJANGO_LOGLEVEL=info
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1 # 允许的主机名
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com # CSRF配置

API_KEY=<随机字符串> # 前后端数据交换密钥 需要与前端相同
SERVER_NAME=example.com # 服务器名称
FRONTEND_URL=http://localhost:3000 # 前端地址
BACKEND_DOMAIN=example.com

# postgresql 数据库配置
DATABASE_ENGINE=postgresql
DATABASE_NAME=blog
DATABASE_USER=blog
DATABASE_PASSWORD=<数据库密码>
DATABASE_HOST=localhost
DATABASE_PORT=5432

# redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
# 上面的配置也可以使用下面的方式替代
#REDIS_URL=redis://localhost:6379

# s3 配置
USE_S3=False # 是否使用 S3 对象存储上传图片
S3_ENDPOINT_URL=xxx # S3 Endpoint URL
S3_ACCESS_KEY_ID=xxx # S3 Access Key ID
S3_SECRET_ACCESS_KEY=xxx # S3 Secret Access Key
S3_BUCKET_NAME=xxx # bucket
S3_PUBLIC_DOMAIN=xxx

# resend 邮件配置
RESEND_API_KEY=xxx # Resend API Key
ADMIN_EMAIL=admin@example.com # 管理员邮箱
DEFAULT_FROM_EMAIL="admin@example.com" # 或者 "Name <email@example.com>"

# 向量化搜索
MODEL_NAME=google/embeddinggemma-300m
GGUF_MODEL_NAME=ggml-org/embeddinggemma-300M-GGUF # 与 MODEL_NAME 二选一即可, 如果使用gguf, 还需要启用 litellm
SENTENCE_TRANSFORMERS_HOME=sentence_transformers_models
HUGGINGFACE_HUB_TOKEN=hf_xxx # 下载某些模型需要, 比如 google/embeddinggemma-300m

# 使用外部的模型提供词嵌入 (可选，用于替代本地推理)
USE_REMOTE_EMBEDDING=False
REMOTE_EMBEDDING_API_BASE=http://blog-litellm:4000/v1
REMOTE_EMBEDDING_MODEL_NAME=embeddinggemma-300m
REMOTE_EMBEDDING_API_KEY=sk-1234  # change this in prod

# 私有 Registry 仓库
REGISTRY_DOMAIN=registry.example.com
REGISTRY_USER=user
REGISTRY_PASSWD=passwd
